# Mirage Mock 运行环境变量（拷贝为 mirage-mock.env 并填入真实值，勿提交真实密码）
# 部署路径示例：/opt/mirage-mock/mirage-mock.env，由 systemd EnvironmentFile 读取

# profile：prod=MySQL，local=H2 内存（生产用 prod）
MIRAGE_PROFILE=prod

# MySQL 连接（Flyway 首次启动自动建表；库需提前建好）
MIRAGE_DB_URL=jdbc:mysql://localhost:3306/mirage?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
MIRAGE_DB_USER=mirage
MIRAGE_DB_PASSWORD=改成强密码

# 安全密钥（生产必须覆盖；用 openssl rand -base64 48 生成）
MIRAGE_JWT_SECRET=用 openssl rand -base64 48 生成的随机串
MIRAGE_MASTER_KEY=用 openssl rand -base64 48 生成的随机串
